{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "anhskohbo/no-captcha": "^3.5",
        "barryvdh/laravel-debugbar": "^3.8",
        "beyondcode/laravel-websockets": "^1.13",
        "doctrine/dbal": "^3.7",
        "guzzlehttp/guzzle": "^7.7",
        "laravel/framework": "^10.10",
        "laravel/sanctum": "^3.2",
        "laravel/tinker": "^2.8",
        "maatwebsite/excel": "^3.1",
        "marcin-orlowski/laravel-api-response-builder": "^8.5",
        "mews/purifier": "^3.4",
        "nikic/php-parser": "^4.19",
        "phpseclib/phpseclib": "^3.0",
        "predis/predis": "^2.2",
        "pusher/pusher-php-server": "^7.2",
        "spatie/laravel-activitylog": "^4.8",
        "spatie/laravel-permission": "^5.11",
        "stichoza/google-translate-php": "^5.1"
    },
    "require-dev": {
        "laravel/pint": "^1.4",
        "laravel/sail": "^1.22",
        "mockery/mockery": "^1.5",
        "nunomaduro/collision": "^6.4",
        "nunomaduro/larastan": "^2.8",
        "phpunit/phpunit": "^10.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\": "Modules/"
        },
        "exclude-from-classmap": [
            "Modules/*/Database/Migrations"
        ],
        "files": [
            "app/Lib/Helpers.php",
            "app/Lib/ReverbPusherHelpers.php",
            "app/Lib/Constant.php",
            "app/Lib/Response.php",
            "Modules/ZoneManagement/Lib/Zone.php",
            "Modules/PromotionManagement/Lib/PromotionNew.php",
            "Modules/BusinessManagement/Lib/BusinessSettingType.php",
            "Modules/Gateways/Library/Constant.php",
            "app/Library/TripRequestUpdate.php",
            "app/Library/CustomerWalletUpdate.php",
            "app/Library/DriverDigitalPay.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan cache:clear"
        ],
        "post-install-cmd": [
            "@php artisan cache:clear"
        ],
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
